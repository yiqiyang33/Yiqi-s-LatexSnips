{
	"name": "yiqis-latexsnips",
	"displayName": "Yiqi's LatexSnips",
	"icon": "images/yiqisnips.png",
	"version": "0.4.8",
	"publisher": "yiqiyang33",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/yiqiyang33/Yiqi-s-LatexSnips"
	},
	"bugs": {
		"url": "https://github.com/yiqiyang33/Yiqi-s-LatexSnips/issues"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Snippets",
		"Other"
	],
	"keywords": [
		"ultisnips",
		"programmable snippets",
		"dynamic snippets",
		"snippets"
	],
	"preview": true,
	"activationEvents": [
		"onStartupFinished",
		"onLanguage:hsnips",
		"onLanguage:markdown",
		"onLanguage:latex",
		"onLanguage:tex",
		"onCommand:hsnips.openSnippetsDir",
		"onCommand:hsnips.openSnippetFile",
		"onCommand:hsnips.reloadSnippets",
		"onCommand:hsnips.smartEnter",
		"onCommand:hsnips.smartTab",
		"onCommand:hsnips.matrixTab"
	],
	"contributes": {
		"configuration": [
			{
				"title": "Yiqi's LatexSnips",
				"properties": {
					"hsnips.multiLineContext": {
						"type": "number",
						"default": 20,
						"description": "Number of lines matched when using multi-line regex mode."
					},
					"hsnips.windows": {
						"type": "string",
						"default": "%APPDATA%/Code/User/hsnips",
						"description": "Custom path for Windows."
					},
					"hsnips.linux": {
						"type": "string",
						"default": "$HOME/.config/Code/User/hsnips",
						"description": "Custom path for Linux."
					},
					"hsnips.mac": {
						"type": "string",
						"default": "$HOME/Library/Application Support/Code/User/hsnips",
						"description": "Custom path for Mac OS."
					}
				}
			}
		],
		"commands": [
			{
				"category": "Yiqi's LatexSnips",
				"command": "hsnips.openSnippetsDir",
				"title": "Open Snippets Directory"
			},
			{
				"category": "Yiqi's LatexSnips",
				"command": "hsnips.openSnippetFile",
				"title": "Open Snippet File"
			},
			{
				"category": "Yiqi's LatexSnips",
				"command": "hsnips.reloadSnippets",
				"title": "Reload Snippets"
			},
			{
				"category": "Yiqi's LatexSnips",
				"command": "hsnips.smartEnter",
				"title": "Smart Math Enter"
			},
			{
				"category": "Yiqi's LatexSnips",
				"command": "hsnips.matrixTab",
				"title": "Insert Matrix Column Separator"
			},
			{
				"category": "Yiqi's LatexSnips",
				"command": "hsnips.smartTab",
				"title": "Smart Alignment Tab"
			}
		],
		"keybindings": [
			{
				"key": "enter",
				"command": "hsnips.smartEnter",
				"when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible"
			},
			{
				"key": "tab",
				"command": "hsnips.smartTab",
				"when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible"
			},
			{
				"key": "shift+tab",
				"command": "hsnips.prevPlaceholder",
				"when": "editorTextFocus && hasPrevTabstop && inSnippetMode"
			},
			{
				"key": "shift+escape",
				"command": "hsnips.leaveSnippet",
				"when": "editorTextFocus && inSnippetMode"
			},
			{
				"key": "escape",
				"command": "hsnips.leaveSnippet",
				"when": "editorTextFocus && inSnippetMode"
			}
		],
		"languages": [
			{
				"id": "hsnips",
				"extensions": [
					".hsnips"
				],
				"aliases": [
					"LatexSnips"
				]
			}
		],
		"grammars": [
			{
				"language": "hsnips",
				"scopeName": "source.hsnips",
				"path": "./syntaxes/hsnips.tmLanguage.json",
				"embeddedLanguages": {
					"meta.embedded.js": "javascript"
				}
			}
		]
	},
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"lint": "tsc --noEmit -p ./",
		"test": "npm run compile && node ./out/test/index.js",
		"check": "npm run lint && npm run test"
	},
	"devDependencies": {
		"@types/node": "18.19.130",
		"@types/vscode": "1.85.0",
		"typescript": "5.4.5"
	}
}
